# ==============================================
# 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# .env 文件已被 .gitignore 忽略，不会被提交
# ==============================================

# 管理员登录密码（默认 admin/admin，生产环境请修改）
# 注意：纯前端 SPA 的认证密码会存在构建产物中
# 部署到 CF 后建议在 CF Dashboard 设置 Access 规则做二次保护
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=admin
