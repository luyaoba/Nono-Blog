# ==============================================
# 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# .env 文件已被 .gitignore 忽略，不会被提交
# ==============================================

# 管理员登录凭证（仅本地开发参考，生产环境请修改）
# 注意：当前认证由后端 Worker 的 D1 admin_users 表处理，前端不会将这两个变量打包到构建产物中
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=admin

# Workers API 地址（默认已配置，仅当自定义域名时需要修改）
VITE_API_URL=https://blog-api.187771.xyz
